import { useState, useEffect, useCallback } from 'react';
import { supabase } from '@/lib/supabase';
import { useAuth } from '@/context/AuthContext';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';

/* ─────────────────────────────────────────────
   DESIGN TOKENS
───────────────────────────────────────────── */
const C = {
  bg:       '#060810',
  surface:  '#0c1120',
  surface2: '#111827',
  surface3: '#1a2438',
  border:   'rgba(255,255,255,0.06)',
  borderHi: 'rgba(255,255,255,0.14)',
  text:     '#eef2ff',
  muted:    '#4b5a7a',
  sub:      '#7d8fb3',
  green:    '#22d3a5',
  blue:     '#60a5fa',
  amber:    '#fbbf24',
  red:      '#f87171',
  indigo:   '#818cf8',
};

const PLAN_COLOR: Record<string, string> = {
  basic:   C.muted,
  pro:     C.blue,
  premium: C.amber,
};

/* ─────────────────────────────────────────────
   HELPERS
───────────────────────────────────────────── */
const fmtDate = (d: any) =>
  d ? new Date(d).toLocaleDateString('en-KE', {
    day: 'numeric', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  }) : '-';
const kes = (n: number) => `KES ${(n || 0).toLocaleString('en-KE')}`;

function semverGt(a: string, b: string): boolean {
  const pa = a.split('.').map(Number);
  const pb = b.split('.').map(Number);
  for (let i = 0; i < 3; i++) {
    if ((pa[i] || 0) > (pb[i] || 0)) return true;
    if ((pa[i] || 0) < (pb[i] || 0)) return false;
  }
  return false;
}

/* ─────────────────────────────────────────────
   TINY UI COMPONENTS
───────────────────────────────────────────── */
function Badge({ label, color }: { label: string; color: string }) {
  return (
    <span style={{
      fontSize: 10, fontWeight: 800, padding: '3px 9px', borderRadius: 20,
      background: `${color}20`, color, textTransform: 'uppercase' as const,
      letterSpacing: '0.05em', whiteSpace: 'nowrap' as const, border: `1px solid ${color}35`,
    }}>
      {label}
    </span>
  );
}

function StatCard({ label, value, color, sub }: any) {
  return (
    <div style={{
      background: C.surface, border: `1px solid ${C.border}`,
      borderRadius: 14, padding: '16px 18px',
    }}>
      <p style={{ margin: '0 0 8px', fontSize: 11, color: C.muted, fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.06em' }}>
        {label}
      </p>
      <p style={{ margin: 0, fontSize: 26, fontWeight: 900, color, letterSpacing: '-0.5px' }}>{value}</p>
      {sub && <p style={{ margin: '4px 0 0', fontSize: 11, color: C.muted }}>{sub}</p>}
    </div>
  );
}

function Pill({ label, active, onClick, count }: any) {
  return (
    <button
      onClick={onClick}
      style={{
        padding: '7px 16px', borderRadius: 30,
        background: active ? C.indigo : 'transparent',
        border: `1px solid ${active ? C.indigo : C.border}`,
        color: active ? '#fff' : C.sub,
        fontSize: 12, fontWeight: 700, cursor: 'pointer', fontFamily: 'inherit',
        display: 'flex', alignItems: 'center', gap: 6, transition: 'all .15s',
      }}
    >
      {label}
      {count !== undefined && (
        <span style={{
          background: active ? 'rgba(255,255,255,0.25)' : C.surface3,
          color: active ? '#fff' : C.muted,
          borderRadius: 20, padding: '1px 7px', fontSize: 10, fontWeight: 800,
        }}>
          {count}
        </span>
      )}
    </button>
  );
}

function ConfirmModal({ message, onConfirm, onCancel, danger }: any) {
  return (
    <div style={{
      position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.8)',
      backdropFilter: 'blur(6px)', zIndex: 600,
      display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 16,
    }}>
      <div style={{
        background: C.surface, border: `1px solid ${C.borderHi}`,
        borderRadius: 18, width: '100%', maxWidth: 380, padding: 24,
      }}>
        <p style={{ margin: '0 0 20px', fontSize: 14, color: C.text, lineHeight: 1.7 }}>{message}</p>
        <div style={{ display: 'flex', gap: 10 }}>
          <button onClick={onCancel} style={{
            flex: 1, padding: '10px', background: 'transparent',
            border: `1px solid ${C.border}`, borderRadius: 10,
            color: C.sub, fontWeight: 700, fontSize: 13, cursor: 'pointer', fontFamily: 'inherit',
          }}>
            Cancel
          </button>
          <button onClick={onConfirm} style={{
            flex: 1, padding: '10px',
            background: danger ? C.red : C.green,
            border: 'none', borderRadius: 10,
            color: danger ? '#fff' : '#011a10', fontWeight: 800, fontSize: 13,
            cursor: 'pointer', fontFamily: 'inherit',
          }}>
            Confirm
          </button>
        </div>
      </div>
    </div>
  );
}

/* ─────────────────────────────────────────────
   VERSION FORM (add / edit)
───────────────────────────────────────────── */
interface VersionForm {
  version: string;
  changelog: string;
  download_url: string;
  is_required: boolean;
}

const EMPTY_VERSION_FORM: VersionForm = {
  version: '',
  changelog: '',
  download_url: '',
  is_required: false,
};

function VersionModal({
  initial,
  onSave,
  onClose,
  saving,
}: {
  initial?: VersionForm & { id?: string };
  onSave: (data: VersionForm & { id?: string }) => void;
  onClose: () => void;
  saving: boolean;
}) {
  const [form, setForm] = useState<VersionForm>(initial ?? EMPTY_VERSION_FORM);
  const isEdit = !!initial?.id;

  const set = (k: keyof VersionForm, v: any) => setForm(f => ({ ...f, [k]: v }));

  const inputStyle = {
    width: '100%', padding: '10px 12px',
    background: C.surface2, border: `1px solid ${C.border}`,
    borderRadius: 10, color: C.text, fontSize: 13, fontFamily: 'inherit',
  };

  const labelStyle = {
    display: 'block' as const, fontSize: 11, fontWeight: 700,
    color: C.muted, textTransform: 'uppercase' as const,
    letterSpacing: '0.06em', marginBottom: 6,
  };

  return (
    <div style={{
      position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.85)',
      backdropFilter: 'blur(8px)', zIndex: 600,
      display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 16,
    }}>
      <div style={{
        background: C.surface, border: `1px solid ${C.borderHi}`,
        borderRadius: 18, width: '100%', maxWidth: 480, padding: 28,
      }}>
        <p style={{ margin: '0 0 20px', fontWeight: 900, fontSize: 16, color: C.text }}>
          {isEdit ? 'Edit Version' : 'Publish New Version'}
        </p>

        <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
          {/* Version number */}
          <div>
            <label style={labelStyle}>Version Number *</label>
            <input
              style={inputStyle}
              placeholder="e.g. 1.0.2"
              value={form.version}
              onChange={e => set('version', e.target.value)}
              disabled={isEdit} // don't change version on edit — it's the PK
            />
            {isEdit && (
              <p style={{ margin: '4px 0 0', fontSize: 10, color: C.muted }}>
                Version number cannot be changed after creation.
              </p>
            )}
          </div>

          {/* Changelog */}
          <div>
            <label style={labelStyle}>Changelog *</label>
            <textarea
              style={{ ...inputStyle, minHeight: 100, resize: 'vertical' as const, lineHeight: 1.6 }}
              placeholder={'• Bug fixes and performance improvements\n• New feature X\n• Improved Y'}
              value={form.changelog}
              onChange={e => set('changelog', e.target.value)}
            />
          </div>

          {/* Download URL */}
          <div>
            <label style={labelStyle}>Download URL</label>
            <input
              style={inputStyle}
              placeholder="https://github.com/yourrepo/releases/download/v1.0.2/App.apk"
              value={form.download_url}
              onChange={e => set('download_url', e.target.value)}
            />
          </div>

          {/* Required toggle */}
          <div style={{
            display: 'flex', alignItems: 'center', justifyContent: 'space-between',
            padding: '12px 14px', background: C.surface3, borderRadius: 11,
            border: `1px solid ${C.border}`,
          }}>
            <div>
              <p style={{ margin: 0, fontWeight: 700, fontSize: 13, color: C.text }}>Force update</p>
              <p style={{ margin: '2px 0 0', fontSize: 11, color: C.muted }}>
                Users must update before continuing. Use with care.
              </p>
            </div>
            <button
              onClick={() => set('is_required', !form.is_required)}
              style={{
                width: 44, height: 24, borderRadius: 12, border: 'none', cursor: 'pointer',
                background: form.is_required ? C.amber : C.surface2,
                position: 'relative', transition: 'background .2s', flexShrink: 0,
              }}
            >
              <span style={{
                position: 'absolute', top: 2,
                left: form.is_required ? 22 : 2,
                width: 20, height: 20, borderRadius: '50%',
                background: form.is_required ? '#011a10' : C.muted,
                transition: 'left .2s',
              }} />
            </button>
          </div>
        </div>

        <div style={{ display: 'flex', gap: 10, marginTop: 22 }}>
          <button
            onClick={onClose}
            style={{
              flex: 1, padding: '11px', background: 'transparent',
              border: `1px solid ${C.border}`, borderRadius: 10,
              color: C.sub, fontWeight: 700, fontSize: 13,
              cursor: 'pointer', fontFamily: 'inherit',
            }}
          >
            Cancel
          </button>
          <button
            disabled={saving || !form.version.trim() || !form.changelog.trim()}
            onClick={() => onSave({ ...form, id: initial?.id })}
            style={{
              flex: 2, padding: '11px',
              background: saving ? C.surface3 : C.indigo,
              border: 'none', borderRadius: 10,
              color: saving ? C.muted : '#fff', fontWeight: 800, fontSize: 13,
              cursor: saving ? 'not-allowed' : 'pointer', fontFamily: 'inherit',
            }}
          >
            {saving ? 'Saving…' : isEdit ? 'Save Changes' : 'Publish Version'}
          </button>
        </div>
      </div>
    </div>
  );
}

/* ─────────────────────────────────────────────
   GLOBAL CSS
───────────────────────────────────────────── */
const CSS = `
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Outfit:wght@400;500;600;700;800;900&display=swap');
  *, *::before, *::after { box-sizing: border-box; }
  .ap-root { font-family: 'Outfit', sans-serif; background: ${C.bg}; color: ${C.text}; min-height: 100vh; }
  .ap-row { transition: background .12s; }
  .ap-row:hover { background: rgba(255,255,255,0.025); }
  input:focus, select:focus, textarea:focus { outline: none; border-color: ${C.indigo} !important; }
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 4px; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn .22s ease forwards; }
  .mono { font-family: 'IBM Plex Mono', monospace; }
`;

/* ─────────────────────────────────────────────
   MAIN COMPONENT
───────────────────────────────────────────── */
export default function AdminPanel() {
  const { user, profile: myProfile } = useAuth();
  const queryClient = useQueryClient();

  // ── Guard: only show to admins ─────────────
  const isAdmin = myProfile?.role === 'admin';

  // ── UI state ───────────────────────────────
  const [tab,          setTab]          = useState<'payments' | 'users' | 'versions'>('payments');
  const [filter,       setFilter]       = useState<'pending' | 'approved' | 'rejected' | 'all'>('pending');
  const [search,       setSearch]       = useState('');
  const [working,      setWorking]      = useState<string | null>(null);
  const [confirm,      setConfirm]      = useState<null | { message: string; danger?: boolean; onConfirm: () => void }>(null);
  const [planEdit,     setPlanEdit]     = useState<null | { userId: string; current: string }>(null);
  const [toast,        setToast]        = useState<string | null>(null);
  const [versionModal, setVersionModal] = useState<null | (VersionForm & { id?: string })>(null);
  const [deleteVerId,  setDeleteVerId]  = useState<string | null>(null);

  /* ── Load data ── */
  const { data: submissions = [], isLoading: loadingSubmissions, refetch: refetchSubmissions } = useQuery({
    queryKey: ['admin_submissions'],
    queryFn: async () => {
      const { data } = await supabase
        .from('payment_submissions')
        .select('*, profiles(email, full_name, plan, phone)')
        .order('submitted_at', { ascending: false });
      return data || [];
    },
    enabled: isAdmin,
    staleTime: 1000 * 60 * 30,
  });

  const { data: users = [], isLoading: loadingUsers, refetch: refetchUsers } = useQuery({
    queryKey: ['admin_users'],
    queryFn: async () => {
      const { data } = await supabase
        .from('profiles')
        .select('id, email, full_name, phone, plan, role, is_active, created_at, last_login')
        .order('created_at', { ascending: false });
      return data || [];
    },
    enabled: isAdmin,
    staleTime: 1000 * 60 * 30,
  });

  const { data: versions = [], isLoading: loadingVersions, refetch: refetchVersions } = useQuery({
    queryKey: ['admin_versions'],
    queryFn: async () => {
      const { data, error } = await supabase
        .from('app_versions')
        .select('*')
        .order('created_at', { ascending: false });
      if (error) throw error;
      return data || [];
    },
    enabled: isAdmin,
    staleTime: 1000 * 60 * 5,
  });

  const loading = loadingSubmissions || loadingUsers || loadingVersions;

  /* ── Toast helper ── */
  const showToast = (msg: string) => {
    setToast(msg);
    setTimeout(() => setToast(null), 3200);
  };

  /* ── Refresh all ── */
  const refreshAll = useCallback(async () => {
    await Promise.all([refetchSubmissions(), refetchUsers(), refetchVersions()]);
    showToast('Refreshed');
  }, [refetchSubmissions, refetchUsers, refetchVersions]);

  /* ── Approve payment ── */
  const approvePayment = async (sub: any) => {
    setWorking(sub.id);
    try {
      const { error: planErr } = await supabase
        .from('profiles')
        .update({ plan: sub.plan_requested, updated_at: new Date().toISOString() })
        .eq('id', sub.user_id);
      if (planErr) throw planErr;

      const { error: subErr, data: updatedSub } = await supabase
        .from('payment_submissions')
        .update({ status: 'approved', reviewed_at: new Date().toISOString() })
        .eq('id', sub.id)
        .select();
      if (subErr) throw subErr;
      if (!updatedSub || updatedSub.length === 0) throw new Error('Update failed: record not found or permission denied');

      await Promise.all([refetchSubmissions(), refetchUsers()]);
      showToast(`Approved — ${sub.profiles?.email} upgraded to ${sub.plan_requested}`);
    } catch (e: any) {
      alert('Error: ' + e.message);
    } finally {
      setWorking(null);
    }
  };

  /* ── Reject payment ── */
  const rejectPayment = async (sub: any) => {
    setWorking(sub.id);
    try {
      await supabase
        .from('payment_submissions')
        .update({ status: 'rejected', reviewed_at: new Date().toISOString() })
        .eq('id', sub.id);
      await refetchSubmissions();
      showToast('Payment rejected');
    } catch (e: any) {
      alert('Error: ' + e.message);
    } finally {
      setWorking(null);
    }
  };

  /* ── Manual plan change ── */
  const updateUserPlan = async (userId: string, newPlan: string) => {
    try {
      const { error } = await supabase
        .from('profiles')
        .update({ plan: newPlan, updated_at: new Date().toISOString() })
        .eq('id', userId);
      if (error) throw error;
      await refetchUsers();
      setPlanEdit(null);
      showToast(`Plan updated to ${newPlan}`);
    } catch (e: any) {
      alert('Error: ' + e.message);
    }
  };

  /* ── Toggle user active ── */
  const toggleActive = async (u: any) => {
    try {
      await supabase.from('profiles').update({ is_active: !u.is_active }).eq('id', u.id);
      await refetchUsers();
      showToast(u.is_active ? 'User deactivated' : 'User activated');
    } catch (e: any) {
      alert('Error: ' + e.message);
    }
  };

  /* ── Version CRUD ── */
  const [versionSaving, setVersionSaving] = useState(false);

  const saveVersion = async (data: VersionForm & { id?: string }) => {
    setVersionSaving(true);
    try {
      if (data.id) {
        // Edit — update by version string (PK)
        const { error } = await supabase
          .from('app_versions')
          .update({
            changelog:    data.changelog,
            download_url: data.download_url,
            is_required:  data.is_required,
          })
          .eq('version', data.version);
        if (error) throw error;
        showToast(`Version ${data.version} updated`);
      } else {
        // New version
        const { error } = await supabase
          .from('app_versions')
          .insert({
            version:      data.version.trim(),
            changelog:    data.changelog.trim(),
            download_url: data.download_url.trim(),
            is_required:  data.is_required,
          });
        if (error) throw error;
        showToast(`Version ${data.version} published`);
      }
      setVersionModal(null);
      await refetchVersions();
    } catch (e: any) {
      alert('Error: ' + e.message);
    } finally {
      setVersionSaving(false);
    }
  };

  const deleteVersion = async (version: string) => {
    try {
      const { error } = await supabase
        .from('app_versions')
        .delete()
        .eq('version', version);
      if (error) throw error;
      await refetchVersions();
      showToast(`Version ${version} deleted`);
    } catch (e: any) {
      alert('Error: ' + e.message);
    }
  };

  /* ── Filtered lists ── */
  const filteredSubs = submissions.filter(s => {
    if (filter !== 'all' && s.status !== filter) return false;
    if (search) {
      const q = search.toLowerCase();
      return (
        s.profiles?.email?.toLowerCase().includes(q) ||
        s.profiles?.full_name?.toLowerCase().includes(q) ||
        s.mpesa_code?.toLowerCase().includes(q) ||
        s.phone?.includes(q)
      );
    }
    return true;
  });

  const filteredUsers = users.filter(u => {
    if (!search) return true;
    const q = search.toLowerCase();
    return (
      u.email?.toLowerCase().includes(q) ||
      u.full_name?.toLowerCase().includes(q) ||
      u.phone?.includes(q)
    );
  });

  /* ── Stats ── */
  const pending   = submissions.filter(s => s.status === 'pending').length;
  const approved  = submissions.filter(s => s.status === 'approved').length;
  const revenue   = submissions.filter(s => s.status === 'approved').reduce((s, x) => s + (x.amount || 0), 0);
  const proUsers  = users.filter(u => u.plan === 'pro').length;
  const premUsers = users.filter(u => u.plan === 'premium').length;

  // Latest version for context
  const latestVersion = versions[0];

  /* ── Guard renders ── */
  if (isAdmin === false) {
    return (
      <div style={{ minHeight: '100vh', background: C.bg, display: 'flex', alignItems: 'center', justifyContent: 'center', flexDirection: 'column', gap: 12 }}>
        <style>{CSS}</style>
        <p style={{ fontSize: 48 }}>🔒</p>
        <p style={{ color: C.text, fontFamily: 'Outfit, sans-serif', fontWeight: 800, fontSize: 18 }}>Access Denied</p>
        <p style={{ color: C.muted, fontFamily: 'Outfit, sans-serif', fontSize: 13 }}>You need admin role to view this page.</p>
      </div>
    );
  }

  if (loading && !myProfile) {
    return (
      <div style={{ minHeight: '100vh', background: C.bg, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <p style={{ color: C.muted, fontFamily: 'Outfit, sans-serif' }}>Verifying permissions...</p>
      </div>
    );
  }

  return (
    <div className="ap-root">
      <style>{CSS}</style>

      {/* ── Toast ─────────────────────────────── */}
      {toast && (
        <div style={{
          position: 'fixed', bottom: 24, left: '50%', transform: 'translateX(-50%)',
          background: C.green, color: '#011a10', padding: '10px 22px', borderRadius: 30,
          fontWeight: 800, fontSize: 13, zIndex: 700, whiteSpace: 'nowrap',
          boxShadow: `0 8px 32px ${C.green}44`,
        }}>
          {toast}
        </div>
      )}

      {/* ── Confirm modal ─────────────────────── */}
      {confirm && (
        <ConfirmModal
          message={confirm.message}
          danger={confirm.danger}
          onConfirm={() => { confirm.onConfirm(); setConfirm(null); }}
          onCancel={() => setConfirm(null)}
        />
      )}

      {/* ── Plan edit modal ───────────────────── */}
      {planEdit && (
        <div style={{
          position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.8)',
          backdropFilter: 'blur(6px)', zIndex: 600,
          display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 16,
        }}>
          <div style={{
            background: C.surface, border: `1px solid ${C.borderHi}`,
            borderRadius: 18, width: '100%', maxWidth: 340, padding: 24,
          }}>
            <p style={{ margin: '0 0 6px', fontWeight: 800, fontSize: 15, color: C.text }}>Change Plan</p>
            <p style={{ margin: '0 0 18px', fontSize: 12, color: C.muted }}>
              Current: <strong style={{ color: PLAN_COLOR[planEdit.current] }}>{planEdit.current}</strong>
            </p>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 8, marginBottom: 16 }}>
              {['basic', 'pro', 'premium'].map(p => (
                <button
                  key={p}
                  onClick={() => updateUserPlan(planEdit.userId, p)}
                  style={{
                    padding: '11px 16px', borderRadius: 11, border: `1px solid ${PLAN_COLOR[p]}40`,
                    background: planEdit.current === p ? `${PLAN_COLOR[p]}20` : 'transparent',
                    color: PLAN_COLOR[p], fontWeight: 800, fontSize: 13, cursor: 'pointer',
                    fontFamily: 'inherit', textAlign: 'left', textTransform: 'uppercase',
                    letterSpacing: '0.04em',
                  }}
                >
                  {planEdit.current === p ? '✓ ' : ''}{p}
                </button>
              ))}
            </div>
            <button
              onClick={() => setPlanEdit(null)}
              style={{
                width: '100%', padding: '10px', background: 'transparent',
                border: `1px solid ${C.border}`, borderRadius: 10,
                color: C.sub, fontWeight: 700, fontSize: 13, cursor: 'pointer', fontFamily: 'inherit',
              }}
            >
              Cancel
            </button>
          </div>
        </div>
      )}

      {/* ── Version modal ─────────────────────── */}
      {versionModal !== null && (
        <VersionModal
          initial={versionModal}
          onSave={saveVersion}
          onClose={() => setVersionModal(null)}
          saving={versionSaving}
        />
      )}

      {/* ── Header ────────────────────────────── */}
      <header style={{
        position: 'sticky', top: 0, zIndex: 100,
        background: 'rgba(6,8,16,0.96)', backdropFilter: 'blur(20px)',
        borderBottom: `1px solid ${C.border}`,
      }}>
        <div style={{
          maxWidth: 1100, margin: '0 auto', padding: '0 20px',
          height: 56, display: 'flex', alignItems: 'center',
          justifyContent: 'space-between', gap: 16,
        }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
            <div style={{
              width: 32, height: 32, borderRadius: 8,
              background: 'linear-gradient(135deg, #818cf8, #60a5fa)',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: 14, fontWeight: 900, color: '#fff',
            }}>
              A
            </div>
            <div>
              <p style={{ margin: 0, fontWeight: 900, fontSize: 14, color: C.text }}>Pesa Pro Admin</p>
              <p style={{ margin: 0, fontSize: 10, color: C.muted }}>Control Panel</p>
            </div>
          </div>

          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="Search users, emails, M-Pesa codes..."
            style={{
              flex: 1, maxWidth: 380, padding: '8px 14px',
              background: C.surface2, border: `1px solid ${C.border}`,
              borderRadius: 10, color: C.text, fontSize: 13, fontFamily: 'inherit',
            }}
          />

          <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
            {pending > 0 && (
              <div style={{
                background: `${C.amber}20`, border: `1px solid ${C.amber}35`,
                borderRadius: 20, padding: '4px 12px', fontSize: 12, color: C.amber, fontWeight: 700,
              }}>
                {pending} pending
              </div>
            )}
            <button
              onClick={refreshAll}
              style={{
                background: C.surface2, border: `1px solid ${C.border}`, borderRadius: 9,
                padding: '7px 13px', color: C.sub, fontSize: 12, fontWeight: 700,
                cursor: 'pointer', fontFamily: 'inherit',
              }}
            >
              Refresh
            </button>
          </div>
        </div>
      </header>

      <div style={{ maxWidth: 1100, margin: '0 auto', padding: '20px 20px 80px' }}>

        {/* ── Stats row ─────────────────────────── */}
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(150px, 1fr))', gap: 12, marginBottom: 24 }} className="fade-in">
          <StatCard label="Pending Reviews" value={pending.toString()}   color={pending > 0 ? C.amber : C.muted} sub="Awaiting approval" />
          <StatCard label="Total Approved"  value={approved.toString()}  color={C.green}  sub="All time" />
          <StatCard label="Revenue"         value={kes(revenue)}         color={C.indigo} sub="Approved payments" />
          <StatCard label="Pro Users"       value={proUsers.toString()}  color={C.blue}   sub={`${premUsers} premium`} />
          <StatCard label="Total Users"     value={users.length.toString()} color={C.sub} sub={`${users.filter(u => u.is_active).length} active`} />
        </div>

        {/* ── Tab switcher ───────────────────────── */}
        <div style={{ display: 'flex', gap: 8, marginBottom: 18, flexWrap: 'wrap' }}>
          <Pill label="Payment Submissions" active={tab === 'payments'} count={submissions.length} onClick={() => { setTab('payments'); setSearch(''); }} />
          <Pill label="All Users"           active={tab === 'users'}    count={users.length}        onClick={() => { setTab('users');    setSearch(''); }} />
          <Pill label="App Versions"        active={tab === 'versions'} count={versions.length}     onClick={() => { setTab('versions'); setSearch(''); }} />
        </div>

        {/* ══ PAYMENTS TAB ════════════════════════ */}
        {tab === 'payments' && (
          <div className="fade-in">
            <div style={{ display: 'flex', gap: 6, marginBottom: 16, flexWrap: 'wrap' }}>
              {(['pending', 'approved', 'rejected', 'all'] as const).map(f => (
                <button
                  key={f}
                  onClick={() => setFilter(f)}
                  style={{
                    padding: '5px 14px', borderRadius: 20, border: `1px solid ${filter === f ? C.indigo : C.border}`,
                    background: filter === f ? `${C.indigo}20` : 'transparent',
                    color: filter === f ? C.indigo : C.muted,
                    fontSize: 12, fontWeight: 700, cursor: 'pointer', fontFamily: 'inherit',
                    textTransform: 'capitalize',
                  }}
                >
                  {f} {f !== 'all' && `(${submissions.filter(s => s.status === f).length})`}
                </button>
              ))}
            </div>

            {loadingSubmissions
              ? <p style={{ color: C.muted, textAlign: 'center', padding: 48 }}>Loading...</p>
              : filteredSubs.length === 0
                ? (
                  <div style={{ textAlign: 'center', padding: '48px 20px', background: C.surface, border: `1px solid ${C.border}`, borderRadius: 16 }}>
                    <p style={{ color: C.text, fontWeight: 700, fontSize: 15, margin: '0 0 8px' }}>No submissions</p>
                    <p style={{ color: C.muted, fontSize: 13, margin: 0 }}>
                      {filter === 'pending' ? 'No pending payments to review.' : `No ${filter} submissions found.`}
                    </p>
                  </div>
                )
                : (
                  <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 16, overflow: 'hidden' }}>
                    <div style={{
                      display: 'grid',
                      gridTemplateColumns: '1fr 1fr 100px 90px 100px 80px 160px',
                      padding: '10px 18px', borderBottom: `1px solid ${C.border}`,
                      fontSize: 10, fontWeight: 800, color: C.muted, textTransform: 'uppercase', letterSpacing: '0.07em',
                    }}>
                      <span>User</span><span>M-Pesa Code</span><span>Amount</span>
                      <span>Plan</span><span>Status</span><span>Submitted</span>
                      <span style={{ textAlign: 'right' }}>Actions</span>
                    </div>

                    {filteredSubs.map((s, i) => {
                      const isWorking = working === s.id;
                      return (
                        <div
                          key={s.id}
                          className="ap-row"
                          style={{
                            display: 'grid',
                            gridTemplateColumns: '1fr 1fr 100px 90px 100px 80px 160px',
                            padding: '13px 18px',
                            borderBottom: i < filteredSubs.length - 1 ? `1px solid ${C.border}` : 'none',
                            alignItems: 'center', gap: 8,
                          }}
                        >
                          <div style={{ minWidth: 0 }}>
                            <p style={{ margin: 0, fontWeight: 700, fontSize: 13, color: C.text, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                              {s.profiles?.full_name || 'Unknown'}
                            </p>
                            <p style={{ margin: '2px 0 0', fontSize: 11, color: C.muted, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                              {s.profiles?.email || s.phone}
                            </p>
                          </div>
                          <div>
                            <p className="mono" style={{ margin: 0, fontSize: 12, color: C.green, fontWeight: 700, letterSpacing: '0.03em' }}>{s.mpesa_code}</p>
                            <p style={{ margin: '2px 0 0', fontSize: 10, color: C.muted }}>{s.phone}</p>
                          </div>
                          <p style={{ margin: 0, fontWeight: 800, fontSize: 13, color: C.text }}>{kes(s.amount)}</p>
                          <Badge label={s.plan_requested} color={PLAN_COLOR[s.plan_requested] || C.muted} />
                          <Badge label={s.status} color={s.status === 'approved' ? C.green : s.status === 'rejected' ? C.red : C.amber} />
                          <p style={{ margin: 0, fontSize: 10, color: C.muted, lineHeight: 1.5 }}>{fmtDate(s.submitted_at).split(',')[0]}</p>
                          <div style={{ display: 'flex', gap: 6, justifyContent: 'flex-end' }}>
                            {s.status === 'pending' && (
                              <>
                                <button
                                  disabled={isWorking}
                                  onClick={() => setConfirm({
                                    message: `Approve ${kes(s.amount)} payment from ${s.profiles?.email || s.phone}? This will upgrade their plan to ${s.plan_requested}.`,
                                    onConfirm: () => approvePayment(s),
                                  })}
                                  style={{
                                    padding: '5px 12px', background: `${C.green}20`,
                                    border: `1px solid ${C.green}35`, borderRadius: 8,
                                    color: C.green, fontSize: 11, fontWeight: 800,
                                    cursor: isWorking ? 'not-allowed' : 'pointer',
                                    fontFamily: 'inherit', opacity: isWorking ? 0.5 : 1,
                                  }}
                                >
                                  {isWorking ? '...' : 'Approve'}
                                </button>
                                <button
                                  disabled={isWorking}
                                  onClick={() => setConfirm({
                                    message: `Reject this payment from ${s.profiles?.email || s.phone}? Their plan will not change.`,
                                    danger: true,
                                    onConfirm: () => rejectPayment(s),
                                  })}
                                  style={{
                                    padding: '5px 12px', background: `${C.red}15`,
                                    border: `1px solid ${C.red}30`, borderRadius: 8,
                                    color: C.red, fontSize: 11, fontWeight: 800,
                                    cursor: isWorking ? 'not-allowed' : 'pointer',
                                    fontFamily: 'inherit', opacity: isWorking ? 0.5 : 1,
                                  }}
                                >
                                  Reject
                                </button>
                              </>
                            )}
                            {s.status !== 'pending' && (
                              <span style={{ fontSize: 11, color: C.muted }}>{fmtDate(s.reviewed_at).split(',')[0]}</span>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )
            }
          </div>
        )}

        {/* ══ USERS TAB ═══════════════════════════ */}
        {tab === 'users' && (
          <div className="fade-in">
            {loadingUsers
              ? <p style={{ color: C.muted, textAlign: 'center', padding: 48 }}>Loading...</p>
              : (
                <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 16, overflow: 'hidden' }}>
                  <div style={{
                    display: 'grid',
                    gridTemplateColumns: '1fr 140px 90px 80px 140px 180px',
                    padding: '10px 18px', borderBottom: `1px solid ${C.border}`,
                    fontSize: 10, fontWeight: 800, color: C.muted,
                    textTransform: 'uppercase', letterSpacing: '0.07em',
                  }}>
                    <span>User</span><span>Phone</span><span>Plan</span>
                    <span>Status</span><span>Joined</span>
                    <span style={{ textAlign: 'right' }}>Actions</span>
                  </div>

                  {filteredUsers.length === 0 && (
                    <p style={{ textAlign: 'center', padding: '40px 20px', color: C.muted, fontSize: 13 }}>No users found</p>
                  )}

                  {filteredUsers.map((u, i) => (
                    <div
                      key={u.id}
                      className="ap-row"
                      style={{
                        display: 'grid',
                        gridTemplateColumns: '1fr 140px 90px 80px 140px 180px',
                        padding: '13px 18px',
                        borderBottom: i < filteredUsers.length - 1 ? `1px solid ${C.border}` : 'none',
                        alignItems: 'center', gap: 8,
                      }}
                    >
                      <div style={{ minWidth: 0 }}>
                        <p style={{ margin: 0, fontWeight: 700, fontSize: 13, color: C.text, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                          {u.full_name || 'No name'}
                          {u.role === 'admin' && (
                            <span style={{ marginLeft: 6, fontSize: 9, fontWeight: 800, color: C.indigo, background: `${C.indigo}20`, padding: '1px 6px', borderRadius: 10, textTransform: 'uppercase' }}>
                              admin
                            </span>
                          )}
                        </p>
                        <p style={{ margin: '2px 0 0', fontSize: 11, color: C.muted, overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                          {u.email}
                        </p>
                      </div>
                      <p className="mono" style={{ margin: 0, fontSize: 11, color: C.sub }}>{u.phone || '-'}</p>
                      <Badge label={u.plan} color={PLAN_COLOR[u.plan] || C.muted} />
                      <Badge label={u.is_active ? 'Active' : 'Off'} color={u.is_active ? C.green : C.red} />
                      <p style={{ margin: 0, fontSize: 11, color: C.muted }}>{fmtDate(u.created_at).split(',')[0]}</p>
                      <div style={{ display: 'flex', gap: 6, justifyContent: 'flex-end', flexWrap: 'wrap' }}>
                        <button
                          onClick={() => setPlanEdit({ userId: u.id, current: u.plan })}
                          style={{
                            padding: '5px 11px', background: `${PLAN_COLOR[u.plan]}15`,
                            border: `1px solid ${PLAN_COLOR[u.plan]}30`, borderRadius: 8,
                            color: PLAN_COLOR[u.plan], fontSize: 11, fontWeight: 800,
                            cursor: 'pointer', fontFamily: 'inherit',
                          }}
                        >
                          Change Plan
                        </button>
                        {u.role !== 'admin' && (
                          <button
                            onClick={() => setConfirm({
                              message: `${u.is_active ? 'Deactivate' : 'Activate'} ${u.email}?`,
                              danger: u.is_active,
                              onConfirm: () => toggleActive(u),
                            })}
                            style={{
                              padding: '5px 11px',
                              background: u.is_active ? `${C.red}12` : `${C.green}12`,
                              border: `1px solid ${u.is_active ? C.red : C.green}30`,
                              borderRadius: 8,
                              color: u.is_active ? C.red : C.green,
                              fontSize: 11, fontWeight: 800,
                              cursor: 'pointer', fontFamily: 'inherit',
                            }}
                          >
                            {u.is_active ? 'Deactivate' : 'Activate'}
                          </button>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              )
            }
          </div>
        )}

        {/* ══ VERSIONS TAB ════════════════════════ */}
        {tab === 'versions' && (
          <div className="fade-in">

            {/* Header row */}
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16, flexWrap: 'wrap', gap: 10 }}>
              <div>
                <p style={{ margin: 0, fontWeight: 800, fontSize: 15, color: C.text }}>App Versions</p>
                <p style={{ margin: '3px 0 0', fontSize: 12, color: C.muted }}>
                  Manage release versions and update banners shown to users.
                  {latestVersion && (
                    <> Latest: <span className="mono" style={{ color: C.green }}>{latestVersion.version}</span></>
                  )}
                </p>
              </div>
              <button
                onClick={() => setVersionModal({ ...EMPTY_VERSION_FORM })}
                style={{
                  padding: '9px 18px', background: C.indigo, border: 'none',
                  borderRadius: 10, color: '#fff', fontSize: 13, fontWeight: 800,
                  cursor: 'pointer', fontFamily: 'inherit',
                  display: 'flex', alignItems: 'center', gap: 7,
                }}
              >
                <span style={{ fontSize: 16, lineHeight: 1 }}>+</span> Publish Version
              </button>
            </div>

            {/* Info callout */}
            <div style={{
              background: `${C.blue}10`, border: `1px solid ${C.blue}25`,
              borderRadius: 12, padding: '12px 16px', marginBottom: 18,
              display: 'flex', gap: 10, alignItems: 'flex-start',
            }}>
              <span style={{ fontSize: 16, flexShrink: 0 }}>ℹ️</span>
              <p style={{ margin: 0, fontSize: 12, color: C.sub, lineHeight: 1.6 }}>
                The update banner in the app appears when the database contains a version newer than the
                hardcoded <span className="mono" style={{ color: C.blue }}>APP_VERSION</span> in{' '}
                <span className="mono" style={{ color: C.blue }}>App.tsx</span>.
                Publishing a higher version here will trigger the banner for all users on older builds.
                Enable <strong style={{ color: C.amber }}>Force update</strong> to block access until users upgrade.
              </p>
            </div>

            {loadingVersions
              ? <p style={{ color: C.muted, textAlign: 'center', padding: 48 }}>Loading versions...</p>
              : versions.length === 0
                ? (
                  <div style={{
                    textAlign: 'center', padding: '56px 20px',
                    background: C.surface, border: `1px solid ${C.border}`, borderRadius: 16,
                  }}>
                    <p style={{ fontSize: 32, margin: '0 0 12px' }}>📦</p>
                    <p style={{ color: C.text, fontWeight: 700, fontSize: 15, margin: '0 0 6px' }}>No versions yet</p>
                    <p style={{ color: C.muted, fontSize: 13, margin: '0 0 20px' }}>
                      Publish your first version to start showing update banners.
                    </p>
                    <button
                      onClick={() => setVersionModal({ ...EMPTY_VERSION_FORM })}
                      style={{
                        padding: '10px 22px', background: C.indigo, border: 'none',
                        borderRadius: 10, color: '#fff', fontSize: 13, fontWeight: 800,
                        cursor: 'pointer', fontFamily: 'inherit',
                      }}
                    >
                      Publish First Version
                    </button>
                  </div>
                )
                : (
                  <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
                    {versions.map((v: any, i: number) => {
                      const isLatest = i === 0;
                      return (
                        <div
                          key={v.version}
                          style={{
                            background: C.surface,
                            border: `1px solid ${isLatest ? C.indigo + '50' : C.border}`,
                            borderRadius: 14, padding: '16px 20px',
                            display: 'flex', alignItems: 'flex-start',
                            gap: 16, flexWrap: 'wrap',
                          }}
                        >
                          {/* Version badge + meta */}
                          <div style={{ flex: '0 0 auto', minWidth: 120 }}>
                            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 6 }}>
                              <span className="mono" style={{ fontSize: 20, fontWeight: 900, color: isLatest ? C.indigo : C.text, letterSpacing: '-0.5px' }}>
                                v{v.version}
                              </span>
                              {isLatest && <Badge label="Latest" color={C.indigo} />}
                            </div>
                            <p style={{ margin: '0 0 4px', fontSize: 11, color: C.muted }}>
                              Published {fmtDate(v.created_at).split(',')[0]}
                            </p>
                            <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
                              {v.is_required && <Badge label="Force Update" color={C.amber} />}
                              {v.download_url && <Badge label="Has APK" color={C.green} />}
                            </div>
                          </div>

                          {/* Changelog */}
                          <div style={{ flex: 1, minWidth: 200 }}>
                            <p style={{ margin: '0 0 6px', fontSize: 10, fontWeight: 800, color: C.muted, textTransform: 'uppercase', letterSpacing: '0.06em' }}>
                              Changelog
                            </p>
                            <pre style={{
                              margin: 0, fontSize: 12, color: C.sub,
                              fontFamily: 'Outfit, sans-serif', lineHeight: 1.7,
                              whiteSpace: 'pre-wrap', wordBreak: 'break-word',
                            }}>
                              {v.changelog}
                            </pre>
                          </div>

                          {/* Download URL */}
                          {v.download_url && (
                            <div style={{ flex: '0 0 auto', maxWidth: 220, minWidth: 0 }}>
                              <p style={{ margin: '0 0 4px', fontSize: 10, fontWeight: 800, color: C.muted, textTransform: 'uppercase', letterSpacing: '0.06em' }}>
                                Download URL
                              </p>
                              <a
                                href={v.download_url}
                                target="_blank"
                                rel="noopener noreferrer"
                                style={{
                                  fontSize: 11, color: C.blue,
                                  textDecoration: 'none', wordBreak: 'break-all',
                                  display: 'block',
                                }}
                              >
                                {v.download_url.length > 50 ? v.download_url.slice(0, 50) + '…' : v.download_url}
                              </a>
                            </div>
                          )}

                          {/* Actions */}
                          <div style={{ display: 'flex', gap: 7, alignItems: 'center', flexShrink: 0, alignSelf: 'center' }}>
                            <button
                              onClick={() => setVersionModal({
                                id:           v.version,
                                version:      v.version,
                                changelog:    v.changelog,
                                download_url: v.download_url || '',
                                is_required:  v.is_required,
                              })}
                              style={{
                                padding: '6px 13px', background: `${C.indigo}15`,
                                border: `1px solid ${C.indigo}30`, borderRadius: 8,
                                color: C.indigo, fontSize: 11, fontWeight: 800,
                                cursor: 'pointer', fontFamily: 'inherit',
                              }}
                            >
                              Edit
                            </button>
                            <button
                              onClick={() => setConfirm({
                                message: `Delete version ${v.version}? This cannot be undone. Users currently on this version will no longer see it listed.`,
                                danger: true,
                                onConfirm: () => deleteVersion(v.version),
                              })}
                              style={{
                                padding: '6px 13px', background: `${C.red}12`,
                                border: `1px solid ${C.red}25`, borderRadius: 8,
                                color: C.red, fontSize: 11, fontWeight: 800,
                                cursor: 'pointer', fontFamily: 'inherit',
                              }}
                            >
                              Delete
                            </button>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )
            }
          </div>
        )}
      </div>
    </div>
  );
}